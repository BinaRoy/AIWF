{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "run_id",
    "name",
    "status",
    "command",
    "exit_code",
    "ts_start",
    "ts_end",
    "duration_seconds",
    "evidence",
    "metrics",
    "environment"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "skip"
      ]
    },
    "command": {
      "type": [
        "string",
        "null"
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "ts_start": {
      "type": "string"
    },
    "ts_end": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "number"
    },
    "evidence": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "environment": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
