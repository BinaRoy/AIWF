{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "risks"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "mitigated",
              "accepted"
            ]
          },
          "waiver": {
            "type": "object",
            "required": [
              "reason",
              "issued_at",
              "expires_at"
            ],
            "properties": {
              "reason": {
                "type": "string"
              },
              "issued_at": {
                "type": "string"
              },
              "expires_at": {
                "type": "string"
              },
              "approved_by": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
