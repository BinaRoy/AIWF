{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "work_items",
    "handoffs",
    "transitions",
    "summary"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "work_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "owner_role",
          "created_at",
          "updated_at",
          "acceptance_refs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "handoff",
              "review",
              "done",
              "blocked"
            ]
          },
          "owner_role": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "acceptance_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "work_item_id",
          "from_role",
          "to_role",
          "timestamp"
        ],
        "properties": {
          "work_item_id": {
            "type": "string"
          },
          "from_role": {
            "type": "string"
          },
          "to_role": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timestamp": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "work_item_id",
          "from_status",
          "to_status",
          "timestamp"
        ],
        "properties": {
          "work_item_id": {
            "type": "string"
          },
          "from_status": {
            "type": "string"
          },
          "to_status": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_work_items",
        "pending",
        "in_progress",
        "handoff",
        "review",
        "done",
        "blocked",
        "handoff_count",
        "transition_count"
      ],
      "properties": {
        "total_work_items": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "in_progress": {
          "type": "integer",
          "minimum": 0
        },
        "handoff": {
          "type": "integer",
          "minimum": 0
        },
        "review": {
          "type": "integer",
          "minimum": 0
        },
        "done": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "handoff_count": {
          "type": "integer",
          "minimum": 0
        },
        "transition_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
