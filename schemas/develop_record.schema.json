{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "mode",
    "verified",
    "ok",
    "steps",
    "artifacts"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "preflight"
      ]
    },
    "verified": {
      "type": "boolean"
    },
    "ok": {
      "type": "boolean"
    },
    "steps": {
      "type": "object",
      "properties": {
        "plan": {
          "type": "object"
        },
        "roles_sync": {
          "type": "object"
        },
        "verify": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "required": [
        "run_record",
        "develop_record",
        "gate_reports",
        "telemetry"
      ],
      "properties": {
        "run_record": {
          "type": "string"
        },
        "develop_record": {
          "type": "string"
        },
        "dispatch_record": {
          "type": [
            "string",
            "null"
          ]
        },
        "gate_reports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "telemetry": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
