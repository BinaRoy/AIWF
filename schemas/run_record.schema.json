{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "stage",
    "run_type",
    "result",
    "ok",
    "artifacts"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "run_type": {
      "type": "string",
      "enum": [
        "develop",
        "verify"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "partial"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "preflight"
      ]
    },
    "verified": {
      "type": "boolean"
    },
    "ok": {
      "type": "boolean"
    },
    "steps": {
      "type": "object"
    },
    "results": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "run_record",
        "gate_reports",
        "telemetry"
      ],
      "properties": {
        "run_record": {
          "type": "string"
        },
        "develop_record": {
          "type": [
            "string",
            "null"
          ]
        },
        "dispatch_record": {
          "type": [
            "string",
            "null"
          ]
        },
        "gate_reports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "telemetry": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
